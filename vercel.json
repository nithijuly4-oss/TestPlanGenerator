{
  "version": 2,
  "env": {
    "GROQ_API_KEY": {
      "description": "Your GROQ LLM API Key"
    },
    "JIRA_EMAIL": {
      "description": "Your Jira Cloud Email"
    },
    "JIRA_API_TOKEN": {
      "description": "Your Jira Cloud API Token"
    },
    "JIRA_DOMAIN": {
      "description": "Your Jira Cloud Domain"
    }
  },
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nodejs",
  "functions": {
    "server.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/$1",
      "status": 200
    }
  ]
}
